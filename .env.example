# ─────────────────────────────────────────────────────────────
# Know AI ERP - Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/knowai_erp"

# ── Authentication ───────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-secret-key"
NEXTAUTH_SECRET="change-this-to-another-random-secret"
NEXTAUTH_URL="http://localhost:3001"

# ── Email / SMTP ─────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# ── Application ──────────────────────────────────────────────
NODE_ENV="development"

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL="http://localhost:3001"

# ── Docker Database (used by backup/restore scripts) ─────────
# DB_NAME="knowai_erp"
# DB_USER="postgres"
# DB_HOST="localhost"
# DB_PORT="5432"
# PGPASSWORD="postgres"
