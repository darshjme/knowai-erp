DATABASE_URL=postgresql://user:password@localhost:5432/knowai_erp
JWT_SECRET=your-jwt-secret-here
NODE_ENV=development
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/your-project-id
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=KnowAI ERP <noreply@yourdomain.com>
CRON_SECRET=your-cron-secret-here

# S3-compatible storage (Hetzner Object Storage, AWS S3, MinIO, etc.)
# When S3_ENDPOINT is set, file uploads go to S3. Otherwise, local filesystem is used.
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=knowai-erp
S3_REGION=fsn1
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key

# Figma API (for design token sync)
FIGMA_ACCESS_TOKEN=your-figma-personal-access-token
FIGMA_FILE_KEY=your-figma-file-key
